<UserControl x:Class="SystemUI.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900"
             Background="#2d283e">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- AboutView's own nav bar (keep this, just fix the handlers) -->
        <Grid Background="#2A1B3D" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="15"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="1"
                   Width="20" Height="20"
                   Source="/Assets/listen.png"
                   RenderOptions.BitmapScalingMode="Fant"
                   VerticalAlignment="Center"/>

            <!-- MusicLib brand — clicking goes back to home -->
            <TextBlock Text="MusicLib"
                       Foreground="White"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Cursor="Hand"
                       MouseLeftButtonUp="Nav_Home"/>

            <!-- Login link — now wired -->
            <TextBlock Text="Login"
                       Foreground="LightGray"
                       Grid.Column="4"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Cursor="Hand"
                       MouseLeftButtonUp="Nav_Login"/>

            <!-- About link — active page, no navigation needed -->
            <TextBlock Text="About"
                       Foreground="White"
                       Grid.Column="5"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Cursor="Hand"/>
        </Grid>

        <Image Grid.Row="1" Grid.Column="0"
               Source="/Assets/sidepic3.jpg"
               Opacity="0.3"
               RenderOptions.BitmapScalingMode="Fant"
               Stretch="UniformToFill"/>

        <StackPanel Grid.Row="1" Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="20,0,40,0">

            <TextBlock Text="About MusicLib"
                       Foreground="#a855f7"
                       FontSize="30"
                       FontWeight="Bold"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,2"/>

            <TextBlock Text="by Alyssa Mae Brucelo"
                       Foreground="LightGray"
                       FontSize="16"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,14"/>

            <TextBlock Text="Description"
                       Foreground="#a855f7"
                       FontWeight="Bold"
                       FontSize="14"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,3"/>

            <TextBlock Text="MusicLib is a Music Library Information System developed using C# and WPF in compliance for the given activity in Event Driven Programming."
                       Foreground="White"
                       FontSize="13"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       TextWrapping="Wrap"
                       TextAlignment="Justify"
                       Margin="0,0,0,12"/>

            <TextBlock Text="School"
                       Foreground="#a855f7"
                       FontWeight="Bold"
                       FontSize="14"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,3"/>

            <TextBlock Text="Bicol University - College of Science (Information Technology Department)"
                       TextWrapping="Wrap"
                       Foreground="White"
                       FontSize="15"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Technology"
                       Foreground="#a855f7"
                       FontWeight="Bold"
                       FontSize="14"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,3"/>

            <TextBlock Text="Utilizing C# (Specifically WPF with .NET Framework)"
                       Foreground="White"
                       FontSize="15"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,10"/>

            <TextBlock Text="SDGs"
                       FontWeight="Bold"
                       Foreground="#a855f7"
                       FontSize="14"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal">
                <Image Source="/Assets/sdg4-en.png"
                       Width="50" Height="50"
                       RenderOptions.BitmapScalingMode="Fant"
                       Margin="0,0,10,0"/>
                <Image Source="/Assets/sdg9-en.jpg"
                       Width="50" Height="50"
                       RenderOptions.BitmapScalingMode="Fant"
                       Margin="0,0,10,0"/>
                <Image Source="/Assets/sdg11-en.png"
                       Width="50" Height="50"
                       RenderOptions.BitmapScalingMode="Fant"
                       Margin="0,0,10,0"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>