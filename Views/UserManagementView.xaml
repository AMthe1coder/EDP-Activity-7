<UserControl x:Class="SystemUI.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="460" d:DesignWidth="900"
             Background="#2d283e">
    <UserControl.Resources>
        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3d3750"/>
            <Setter Property="FontFamily" Value="Fonts/Samsung.ttf#Samsung Sans"/>
            <Setter Property="Padding" Value="10,6"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#a855f7"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Image Source="/Assets/sidepic1.jpg"
               Stretch="UniformToFill"
               Grid.RowSpan="2"
               Opacity="0.3"/>

        <Grid Background="#2A1B3D" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="15"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="1" Width="20" Height="20" Source="/Assets/listen.png" RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Center"/>
            <TextBlock Text="MusicLib" Foreground="White" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" FontFamily="Fonts/Samsung.ttf#Samsung Sans"/>
            <TextBlock Text="Dashboard" Foreground="LightGray" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Dashboard"/>
            <TextBlock Text="Songs" Foreground="LightGray" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Songs"/>
            <TextBlock Text="Playlists" Foreground="LightGray" Grid.Column="6" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Playlists"/>
            <TextBlock Text="Borrowing" Foreground="LightGray" Grid.Column="7" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Borrowing"/>
            <TextBlock Text="Users" Foreground="White" Grid.Column="8" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans"/>
            <TextBlock Text="Reports" Foreground="LightGray" Grid.Column="9" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Reports"/>
            <TextBlock Text="Logout" Foreground="#a855f7" Grid.Column="10" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Logout"/>
        </Grid>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2A1B3D" CornerRadius="10" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <TextBlock x:Name="lblFormTitle"
                                   Text="Add Account"
                                   Foreground="#a855f7"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                   Margin="0,0,0,16"/>

                        <TextBlock Text="Full Name"
                                   Foreground="LightGray"
                                   FontSize="11"
                                   FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="txtFullName"
                                 Background="#3d3750"
                                 Foreground="White"
                                 FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                 FontSize="12"
                                 BorderThickness="0"
                                 Padding="10,6"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Username"
                                   Foreground="LightGray"
                                   FontSize="11"
                                   FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="txtUser"
                                 Background="#3d3750"
                                 Foreground="White"
                                 FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                 FontSize="12"
                                 BorderThickness="0"
                                 Padding="10,6"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Email"
                                   Foreground="LightGray"
                                   FontSize="11"
                                   FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="txtUserEmail"
                                 Background="#3d3750"
                                 Foreground="White"
                                 FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                 FontSize="12"
                                 BorderThickness="0"
                                 Padding="10,6"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Password"
                                   Foreground="LightGray"
                                   FontSize="11"
                                   FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                   Margin="0,0,0,4"/>
                        <PasswordBox x:Name="txtUserPass"
                                     Background="#3d3750"
                                     Foreground="White"
                                     FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                     FontSize="12"
                                     BorderThickness="0"
                                     Padding="10,6"
                                     Margin="0,0,0,12"/>

                        <TextBlock Text="Status"
                                   Foreground="LightGray"
                                   FontSize="11"
                                   FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                   Margin="0,0,0,4"/>

                        <ComboBox x:Name="cmbStatus"
                                  FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                  FontSize="12"
                                  Margin="0,0,0,16"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItem}">
                            <ComboBox.Template>
                                <ControlTemplate TargetType="ComboBox">
                                    <Grid>
                                        <ToggleButton Background="#3d3750"
                                                      Foreground="White"
                                                      BorderThickness="0"
                                                      Padding="10,6"
                                                      HorizontalContentAlignment="Left"
                                                      IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                      Cursor="Hand">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="4"
                                                            Padding="{TemplateBinding Padding}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition Width="20"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ContentPresenter Grid.Column="0"
                                                                              VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="▾"
                                                                       Foreground="White"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                            <ContentPresenter Content="{Binding Path=SelectionBoxItem, RelativeSource={RelativeSource TemplatedParent}}"
                                                              ContentTemplate="{Binding Path=SelectionBoxItemTemplate, RelativeSource={RelativeSource TemplatedParent}}"
                                                              VerticalAlignment="Center"/>
                                        </ToggleButton>
                                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                               Placement="Bottom"
                                               AllowsTransparency="True">
                                            <Border Background="#3d3750"
                                                    BorderThickness="0"
                                                    CornerRadius="4"
                                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                                <ItemsPresenter/>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </ControlTemplate>
                            </ComboBox.Template>
                            <ComboBoxItem Content="active" IsSelected="True"/>
                            <ComboBoxItem Content="inactive"/>
                        </ComboBox>

                        <TextBlock x:Name="lblFormStatus"
                                   FontSize="11"
                                   FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnSave"
                                    Content="Save"
                                    Foreground="White"
                                    FontSize="12"
                                    FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                    Click="BtnSave_Click"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#a855f7"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#6b21a8"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Width="90" Height="30"
                                                CornerRadius="8"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="Clear"
                                    Foreground="White"
                                    FontSize="12"
                                    FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                    Click="BtnClear_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#3d3750"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#353048"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Width="90" Height="30"
                                                CornerRadius="8"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtSearch"
                             Background="#3d3750"
                             Foreground="White"
                             FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                             FontSize="12"
                             BorderThickness="0"
                             Padding="10,6"
                             Width="220"
                             Margin="0,0,10,0"/>

                    <Button Content="Search"
                            Foreground="White"
                            FontSize="12"
                            FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                            Click="BtnSearch_Click"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#a855f7"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#6b21a8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="80" Height="30"
                                        CornerRadius="8"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Load All"
                            Foreground="White"
                            FontSize="12"
                            FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                            Click="BtnLoadAll_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#3d3750"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#353048"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="80" Height="30"
                                        CornerRadius="8"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <DataGrid x:Name="dgUsers"
                          Grid.Row="2"
                          Background="#2A1B3D"
                          Foreground="White"
                          FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                          FontSize="12"
                          BorderThickness="0"
                          RowBackground="#2A1B3D"
                          AlternatingRowBackground="#3d3750"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="DgUsers_SelectionChanged"
                          CanUserResizeRows="False">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#2A1B3D"/>
                            <Setter Property="Foreground" Value="#a855f7"/>
                            <Setter Property="FontFamily" Value="Fonts/Samsung.ttf#Samsung Sans"/>
                            <Setter Property="Padding" Value="10,6"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"        Binding="{Binding id}"         Width="40"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding full_name}"  Width="*"/>
                        <DataGridTextColumn Header="Username"  Binding="{Binding username}"   Width="*"/>
                        <DataGridTextColumn Header="Email"     Binding="{Binding email}"      Width="*"/>
                        <DataGridTextColumn Header="Status"    Binding="{Binding status}"     Width="70"/>
                        <DataGridTextColumn Header="Created"   Binding="{Binding created_at}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

        </Grid>
    </Grid>
</UserControl>