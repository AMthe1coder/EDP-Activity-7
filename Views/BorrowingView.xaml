<UserControl x:Class="SystemUI.Views.BorrowingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="460" d:DesignWidth="900"
             Background="#2d283e">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Nav -->
        <Grid Background="#2A1B3D" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="15"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="1" Width="20" Height="20" Source="/Assets/listen.png" RenderOptions.BitmapScalingMode="Fant" VerticalAlignment="Center"/>
            <TextBlock Text="MusicLib" Foreground="White" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" FontFamily="Fonts/Samsung.ttf#Samsung Sans"/>
            <TextBlock Text="Dashboard" Foreground="LightGray" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Dashboard"/>
            <TextBlock Text="Songs" Foreground="LightGray" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Songs"/>
            <TextBlock Text="Playlists" Foreground="LightGray" Grid.Column="6" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Playlists"/>
            <TextBlock Text="Borrowing" Foreground="White" Grid.Column="7" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans"/>
            <TextBlock Text="Users" Foreground="LightGray" Grid.Column="8" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Users"/>
            <TextBlock Text="Reports" Foreground="LightGray" Grid.Column="9" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Reports"/>
            <TextBlock Text="Logout" Foreground="#a855f7" Grid.Column="10" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Cursor="Hand" MouseLeftButtonUp="Nav_Logout"/>
        </Grid>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2A1B3D" CornerRadius="10" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="lblFormTitle" Text="New Borrow Record" Foreground="#a855f7" FontSize="16" FontWeight="Bold" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Margin="0,0,0,16"/>

                        <TextBlock Text="Borrower Name" Foreground="LightGray" FontSize="11" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbBorrower" Background="#3d3750" Foreground="White" FontFamily="Fonts/Samsung.ttf#Samsung Sans" FontSize="12" BorderThickness="0" Padding="10,6" Margin="0,0,0,12"/>

                        <TextBlock Text="Song Title" Foreground="LightGray" FontSize="11" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbSongTitle" Background="#3d3750" Foreground="White" FontFamily="Fonts/Samsung.ttf#Samsung Sans" FontSize="12" BorderThickness="0" Padding="10,6" Margin="0,0,0,12"/>

                        <TextBlock Text="Borrowed At (auto)" Foreground="LightGray" FontSize="11" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtBorrowDate" Background="#3d3750" Foreground="White" FontFamily="Fonts/Samsung.ttf#Samsung Sans" FontSize="12" BorderThickness="0" Padding="10,6" Margin="0,0,0,12" IsReadOnly="True"/>

                        <TextBlock Text="Return Date" Foreground="LightGray" FontSize="11" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Margin="0,0,0,4"/>
                        <DatePicker x:Name="dpReturnDate"
                                    Background="#3d3750"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                                    FontSize="12"
                                    Margin="0,0,0,12"/>

                        <TextBlock Text="Status" Foreground="LightGray" FontSize="11" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbBorrowStatus" Background="#3d3750" Foreground="White" FontFamily="Fonts/Samsung.ttf#Samsung Sans" FontSize="12" BorderThickness="0" Padding="10,6" Margin="0,0,0,16">
                            <ComboBoxItem Content="borrowed" IsSelected="True"/>
                            <ComboBoxItem Content="returned"/>
                            <ComboBoxItem Content="overdue"/>
                        </ComboBox>

                        <TextBlock Text="Remarks" Foreground="LightGray" FontSize="11" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtRemarks" Background="#3d3750" Foreground="White" FontFamily="Fonts/Samsung.ttf#Samsung Sans" FontSize="12" BorderThickness="0" Padding="10,6" Margin="0,0,0,16" AcceptsReturn="True" Height="50" TextWrapping="Wrap"/>

                        <TextBlock x:Name="lblFormStatus" FontSize="11" FontFamily="Fonts/Samsung.ttf#Samsung Sans" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnSave" Content="Save" Foreground="White" FontSize="12" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Click="BtnSave_Click" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#a855f7"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Width="90" Height="30" CornerRadius="8" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Delete" Foreground="White" FontSize="12" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Click="BtnDelete_Click" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#c0392b"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Width="90" Height="30" CornerRadius="8" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Clear" Foreground="White" FontSize="12" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Click="BtnClear_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#3d3750"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Width="70" Height="30" CornerRadius="8" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtSearch" Background="#3d3750" Foreground="White" FontFamily="Fonts/Samsung.ttf#Samsung Sans" FontSize="12" BorderThickness="0" Padding="10,6" Width="220" Margin="0,0,10,0"/>
                    <Button Content="Search" Foreground="White" FontSize="12" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Click="BtnSearch_Click" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#a855f7"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="80" Height="30" CornerRadius="8" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Load All" Foreground="White" FontSize="12" FontFamily="Fonts/Samsung.ttf#Samsung Sans" Click="BtnLoadAll_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#3d3750"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="80" Height="30" CornerRadius="8" Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <DataGrid x:Name="dgBorrowing" Grid.Row="2"
                          Background="#2A1B3D" Foreground="White" FontFamily="Fonts/Samsung.ttf#Samsung Sans" FontSize="12"
                          BorderThickness="0" RowBackground="#2A1B3D" AlternatingRowBackground="#3d3750"
                          GridLinesVisibility="None" HeadersVisibility="Column"
                          AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                          SelectionChanged="DgBorrowing_SelectionChanged" CanUserResizeRows="False">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#2A1B3D"/>
                            <Setter Property="Foreground" Value="#a855f7"/>
                            <Setter Property="FontFamily" Value="Fonts/Samsung.ttf#Samsung Sans"/>
                            <Setter Property="Padding" Value="10,6"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"          Binding="{Binding id}"           Width="40"/>
                        <DataGridTextColumn Header="Borrower"    Binding="{Binding borrower_name}" Width="*"/>
                        <DataGridTextColumn Header="Song"        Binding="{Binding song_title}"    Width="*"/>
                        <DataGridTextColumn Header="Borrow Date" Binding="{Binding borrow_date}"   Width="100"/>
                        <DataGridTextColumn Header="Return Date" Binding="{Binding return_date}"   Width="100"/>
                        <DataGridTextColumn Header="Status"      Binding="{Binding status}"        Width="70"/>
                        <DataGridTextColumn Header="Remarks"     Binding="{Binding remarks}"       Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>