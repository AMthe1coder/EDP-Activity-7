<UserControl x:Class="SystemUI.Views.PassRecoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900"
             Background="#2d283e">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Image Grid.Column="0"
               Source="/Assets/sidepic7.jpg"
               Opacity="0.6"
               RenderOptions.BitmapScalingMode="Fant"
               Stretch="UniformToFill"/>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="20,0,40,0">

            <TextBlock Text="Password Recovery"
                       Foreground="#a855f7"
                       FontSize="30"
                       FontWeight="Bold"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,4"/>

            <TextBlock Text="Enter your details to reset your password"
                       Foreground="LightGray"
                       FontSize="13"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Username"
                       Foreground="#a855f7"
                       FontSize="13"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,4"/>

            <TextBox x:Name="txtUsername"
                     Background="#3d3750"
                     Foreground="White"
                     FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                     FontSize="13"
                     BorderThickness="0"
                     Padding="10,6"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Email Address"
                       Foreground="#a855f7"
                       FontSize="13"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,4"/>

            <TextBox x:Name="txtEmail"
                     Background="#3d3750"
                     Foreground="White"
                     FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                     FontSize="13"
                     BorderThickness="0"
                     Padding="10,6"
                     Margin="0,0,0,12"/>

            <TextBlock Text="New Password"
                       Foreground="#a855f7"
                       FontSize="13"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,4"/>

            <PasswordBox x:Name="txtNewPassword"
                         Background="#3d3750"
                         Foreground="White"
                         FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                         FontSize="13"
                         BorderThickness="0"
                         Padding="10,6"
                         Margin="0,0,0,12"/>

            <TextBlock Text="Confirm New Password"
                       Foreground="#a855f7"
                       FontSize="13"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,4"/>

            <PasswordBox x:Name="txtConfirmPassword"
                         Background="#3d3750"
                         Foreground="White"
                         FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                         FontSize="13"
                         BorderThickness="0"
                         Padding="10,6"
                         Margin="0,0,0,12"/>

            <TextBlock x:Name="lblStatus"
                       FontSize="11"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,0,0,10"/>

            <Button Content="Reset Password"
                    Foreground="White"
                    FontSize="13"
                    FontWeight="Medium"
                    FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                    Click="BtnReset_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#a855f7"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6b21a8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Height="32"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock Foreground="#b0b0b0"
                       FontSize="12"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       HorizontalAlignment="Center"
                       Margin="0,14,0,0">
                <Run Text="Remember your password? "/>
                <Run Text="Login" Foreground="#a855f7"
                     MouseLeftButtonUp="LnkLogin_MouseLeftButtonUp"/>
            </TextBlock>

        </StackPanel>
    </Grid>
</UserControl>