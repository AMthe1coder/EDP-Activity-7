<UserControl x:Class="SystemUI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900"
             Background="#2d283e">


    <Grid HorizontalAlignment="Left" Width="900">

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Image Grid.Row="1" Grid.Column="0"
               Source="/Assets/sidepic5.jpg"
               RenderOptions.BitmapScalingMode="Fant"
               Opacity="0.3"
               Stretch="UniformToFill"/>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Width="280"
                    Margin="80,0,0,0">

            <Image Width="50" Height="50"
                   Source="/Assets/listen.png"
                   RenderOptions.BitmapScalingMode="Fant"
                   VerticalAlignment="Center"
                   Margin="0,0,0,5"/>

            <TextBlock Text="Welcome Back!"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

            <TextBlock Text="Sign in to your account"
                       Foreground="LightGray"
                       FontSize="11"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Username"
                       Foreground="LightGray"
                       FontSize="11"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,4"/>

            <TextBox x:Name="txtUsername"
                     Background="#3d3750"
                     Foreground="White"
                     FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                     FontSize="12"
                     BorderThickness="0"
                     Padding="10,6"
                     Margin="0,0,0,12"/>

            <TextBlock Text="Password"
                       Foreground="LightGray"
                       FontSize="11"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       Margin="0,0,0,4"/>

            <PasswordBox x:Name="txtPassword"
                         Background="#3d3750"
                         Foreground="White"
                         FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                         FontSize="12"
                         BorderThickness="0"
                         Padding="10,6"
                         Margin="0,0,0,6"/>

            <TextBlock Text="Forgot password?"
                       Foreground="#a855f7"
                       FontSize="11"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       HorizontalAlignment="Right"
                       Cursor="Hand"
                       Margin="0,0,0,20"
                       MouseLeftButtonUp="LnkForgotPassword_MouseLeftButtonUp"/>

           <TextBlock x:Name="lblError"
           Foreground="#f87171"
           FontSize="11"
           FontFamily="Fonts/Samsung.ttf#Samsung Sans"
           TextWrapping="Wrap"
           Visibility="Collapsed"
           Margin="0,0,0,10"/>

            <Button Content="Login"
                    Foreground="White"
                    FontSize="13"
                    FontWeight="Medium"
                    FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                    Click="BtnLogin_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#a855f7"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6b21a8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Width="280" Height="32"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <TextBlock Foreground="LightGray"
                       FontSize="11"
                       FontFamily="Fonts/Samsung.ttf#Samsung Sans"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,0">
                <Run Text="Don't have an account? "/>
                <Run Text="Register" Foreground="#a855f7"
                     MouseLeftButtonUp="LnkRegister_MouseLeftButtonUp"/>
            </TextBlock>

        </StackPanel>

        <StackPanel Grid.Column="1"/>

    </Grid>
</UserControl>